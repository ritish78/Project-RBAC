{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ESNext"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "strict": true,
    "useUnknownInCatchVariables": false,
    "noImplicitAny": false,
    "target": "ES2022",
    "typeRoots": ["node_modules/@types", "src/types"],
    "paths": {
      "src/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
